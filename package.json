{
  "name": "clawtrade",
  "version": "0.5.0",
  "description": "AI Trading Agent Platform - Trade Crypto, Forex, Stocks & DeFi with AI agents",
  "license": "MIT",
  "author": "Clawtrade",
  "repository": {
    "type": "git",
    "url": "https://github.com/Paparusi/Clawtrade"
  },
  "keywords": [
    "trading",
    "ai",
    "agent",
    "crypto",
    "forex",
    "stocks",
    "defi",
    "binance",
